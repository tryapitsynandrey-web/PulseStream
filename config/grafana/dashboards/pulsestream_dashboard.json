        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "Ingested Events Throughput (by Type)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(pulsestream_events_ingested_total[1m])) by (eventType)",
          "legendFormat": "{{eventType}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "title": "Ingestion Inbound SLA Latency (p95 & p99)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "pulsestream_events_ingestion_duration_seconds{quantile=~\"0.95|0.99\"}",
          "legendFormat": "{{eventType}} ({{quantile}})",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "title": "Failed Ingestion Rates",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(pulsestream_events_ingestion_failed_total[1m])) by (failureType)",
          "legendFormat": "{{failureType}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "id": 4,
      "title": "Database Persistence Durations (p95 / p99)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "pulsestream_persistence_duration_seconds{quantile=~\"0.95|0.99\"}",
          "legendFormat": "{{entityType}} {{operation}} ({{quantile}})",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "id": 5,
      "title": "Outbox Dispatch Processing SLA (p95 / p99)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "pulsestream_outbox_processing_duration_seconds{quantile=~\"0.95|0.99\"}",
          "legendFormat": "Batch ({{quantile}})",
          "refId": "A"
        }
      ]
    }
