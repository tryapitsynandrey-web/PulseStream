# ==============================================================================
# PulseStream Environmental Configuration Template
# Copy this file to '.env' and populate actual values for local deployment.
# Do NOT commit '.env' with real secrets to version control.
# ==============================================================================

# Application Profile & Server
SPRING_PROFILES_ACTIVE=local
PORT=8080

# PostgreSQL Settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pulsestream
DB_USER=postgres
DB_PASSWORD=postgres_secure_pass

# Kafka Settings
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# JWT Security Configurations
# Secure HS256 base64-encoded secret key (minimum 256 bits / 32 bytes)
JWT_SECRET=cHVsc2VzdHJlYW0tZGV2LXNlY3JldC1rZXktZm9yLWxvY2FsLW9ubHktMjAyNDAxMDE=
JWT_EXPIRATION_MS=3600000

# Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
